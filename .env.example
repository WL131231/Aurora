# Aurora 환경변수 템플릿
# 실제 사용 시 이 파일을 .env 로 복사한 뒤 값을 채울 것
# .env 는 절대 커밋되면 안 됨 (.gitignore 처리됨)

# ===== 실행 모드 =====
# paper | demo | live
RUN_MODE=paper

# ===== 거래소 선택 =====
# 데모 = Bybit 확정 (2026-05). 실거래 거래소는 미정 — 협상 중.
# bybit | okx | binance
DEFAULT_EXCHANGE=bybit

# ===== 거래소 API 키 =====
# 사용하는 거래소만 채우면 됨
# Bybit Demo Trading 키 발급: https://www.bybit.com 로그인 → 우상단 Demo Trading
#   → API → Create New Key. ($1M 가상 자금, 실 시장 데이터, ≠ testnet.bybit.com)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_DEMO=true                     # Bybit Demo Trading 모드 (안전). 실거래 시 false

OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

BINANCE_API_KEY=
BINANCE_API_SECRET=

# ===== 시장 메타 데이터 (선물 추세 인지, v0.1.53) =====
# Coinalyze API key — 선물 OI / CVD / Funding 5분 주기 polling.
# 미설정 시 라이브 봇 추세 인지 비활성 (default).
# 발급: https://coinalyze.net/account/api/ (무료 tier 40 calls/min)
COINALYZE_API_KEY=

# ===== 텔레그램 =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== 서버 설정 =====
API_HOST=127.0.0.1
API_PORT=8765

# ===== 로그 =====
LOG_LEVEL=INFO
