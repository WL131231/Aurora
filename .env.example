# UnTrack 환경변수 템플릿
# 실제 사용 시 이 파일을 .env 로 복사한 뒤 값을 채울 것
# .env 는 절대 커밋되면 안 됨 (.gitignore 처리됨)

# ===== 실행 모드 =====
# paper | demo | live
RUN_MODE=paper

# ===== 거래소 API 키 =====
# 사용하는 거래소만 채우면 됨
BYBIT_API_KEY=
BYBIT_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

BINANCE_API_KEY=
BINANCE_API_SECRET=

# ===== 텔레그램 =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== 서버 설정 =====
API_HOST=127.0.0.1
API_PORT=8765

# ===== 로그 =====
LOG_LEVEL=INFO
