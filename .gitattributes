* text=auto

# POSIX shell scripts (Gradle wrapper, etc) — LF 유지 필수
# Why: ubuntu CI 가 CRLF script 실행 시 "bad interpreter ^M" 에러
android/gradlew text eol=lf
*.sh text eol=lf

# Windows batch / PowerShell — CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 바이너리 — diff/merge X
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.exe binary
*.zip binary
*.apk binary
*.jar binary
*.parquet binary
